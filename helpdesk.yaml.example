# Helpdesk configuration. Copy to helpdesk.yaml (or set HELPDESK_CONFIG).
# Every key can be overridden by env: HELPDESK_DATA_DIR, HELPDESK_NATS_URLS, ...

# PocketBase data directory (SQLite database, uploads).
data_dir: pb_data

# Optional operator branding overlay. Point `dir` at a host directory holding
# any of theme.css, logo.svg, and branding.json; the helpdesk serves them under
# /branding/* so an operator can override the app name, logo, and DaisyUI theme
# without rebuilding. branding.json shape: { "appName": "...", "logo": "logo.svg" }.
# Empty / unset (or HELPDESK_BRANDING_DIR) = embedded defaults. See branding.example/.
branding:
  dir: ""

# NATS connection to the platform operator's hub account. Leave urls empty to
# run without NATS (tickets then arrive only via portal/agent/webhook).
#
# The creds file is a Stone-Age.io-issued nats_user in the hub account,
# permission-scoped to `sub helpdesk.>`. Managed customer orgs' ticket events
# are imported into the hub as helpdesk.{platform_org_id}.> by the platform.
# To also emit outbound notification events (see notify_stream), the grant is
# widened to `pub helpdesk.>` — the helpdesk is otherwise blind to it.
nats:
  urls: []
  # urls: ["nats://localhost:4222"]
  creds_file: ""
  stream: HELPDESK_EVENTS
  durable: helpdesk-ingest
  # Outbound notification-event stream the helpdesk creates + owns (subjects
  # helpdesk.*.events.>). Used only when a notification template has
  # publish_nats enabled; setup fails softly if publish isn't granted.
  notify_stream: HELPDESK_NOTIFICATIONS
